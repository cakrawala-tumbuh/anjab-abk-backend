# Konfigurasi backend (12-factor). Salin ke `.env` lalu sesuaikan.

# Identitas & logging
APP_TITLE="ANJAB-ABK Backend"
LOG_LEVEL=INFO

# Bind Uvicorn
HOST=0.0.0.0
PORT=8000

# Dokumentasi API
DOCS_ENABLED=true

# URL publik service → mengisi `servers` di OpenAPI
# PUBLIC_BASE_URL=https://api.example.com

# CORS — daftar origin (format JSON).
# CORS_ORIGINS=["https://app.example.com"]
CORS_ALLOW_CREDENTIALS=false

# Hardening HTTP
MAX_REQUEST_BODY_BYTES=1048576
REQUEST_TIMEOUT_SECONDS=0
ENABLE_SECURITY_HEADERS=true
ENABLE_HSTS=false
ENABLE_COOP=true
GZIP_MIN_SIZE=1024
REQUIRE_IF_MATCH=false

# Auth — parameter validasi token Authentik (seam; tidak ada koneksi langsung di sini)
# AUTHENTIK_ISSUER=https://auth.example.com/application/o/anjab-abk/
# AUTHENTIK_JWKS_URI=https://auth.example.com/application/o/anjab-abk/jwks/
# API_AUDIENCE=anjab-abk

# OAuth2 interaktif untuk Swagger "Authorize" (opsional, doc-only)
# OAUTH2_AUTHORIZATION_URL=https://auth.example.com/application/o/authorize/
# OAUTH2_TOKEN_URL=https://auth.example.com/application/o/token/
# OAUTH2_CLIENT_ID=swagger-ui
# OAUTH2_SCOPES=openid profile email
